

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  PENDING_REVIEW
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_RESUBMISSION
}

enum TransactionType {
  CREDIT
  DEBIT
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
  REVERSED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum IdentificationType {
  NIN
  INTERNATIONAL_PASSPORT
  DRIVERS_LICENSE
  VOTERS_CARD
  RESIDENCE_PERMIT
}

enum ResidencyStatus {
  CITIZEN
  RESIDENT
  NON_RESIDENT
}

// ============================================
// MODELS
// ============================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  status        AccountStatus  @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  profile            CustomerProfile?
  identification     IdentificationRecord?
  address            Address?
  accounts           BankAccount[]
  sessions           Session[]
  passwordResetToken PasswordResetToken?
  auditLogs          AuditLog[]

  @@map("users")
}

model CustomerProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  firstName           String
  middleName          String?
  lastName            String
  dateOfBirth         DateTime
  gender              Gender
  maritalStatus       MaritalStatus
  nationality         String
  phoneNumber         String
  residencyStatus?     ResidencyStatus
  passportNumber      String?
  countryOfCitizenship String?
  profilePhoto        String?           // Cloudinary URL
  verificationStatus  VerificationStatus @default(PENDING_REVIEW)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model IdentificationRecord {
  id                String             @id @default(cuid())
  userId            String             @unique
  idType            IdentificationType
  idNumber          String
  governmentIdFile  String?            // Cloudinary URL
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identification_records")
}

model Address {
  id                  String   @id @default(cuid())
  userId              String   @unique
  residentialAddress  String
  apartmentSuite      String?
  city                String
  state               String
  country             String
  postalCode          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model BankAccount {
  id            String         @id @default(cuid())
  userId        String
  customerId    String         @unique
  accountNumber String         @unique
  routingNumber String
  balance       Decimal        @default(0) @db.Decimal(12, 2)
  accountType   String         @default("CHECKING")
  status        AccountStatus  @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@index([accountNumber])
  @@map("bank_accounts")
}

model Transaction {
  id              String            @id @default(cuid())
  accountId       String
  transactionType TransactionType
  amount          Decimal           @db.Decimal(12, 2)
  description     String
  status          TransactionStatus @default(COMPLETED)
  createdByAdmin  String?
  reference       String            @unique
  createdAt       DateTime          @default(now())

  account BankAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([createdAt])
  @@map("transactions")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  userId  String   @unique
  token   String   @unique
  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AuditLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  details      Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}