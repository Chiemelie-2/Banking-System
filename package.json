    "@supabase/supabase-js": "^2.106.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "framer-motion": "^12.39.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
